# ── Google OAuth2 ──────────────────────────────
# Google Cloud Console → APIとサービス → 認証情報 → OAuth2クライアントID から取得
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── セッション署名キー ──────────────────────────
# 以下コマンドで生成: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-hex-string

# ── アプリのベースURL ───────────────────────────
# ローカル開発
BASE_URL=http://localhost:8000
# Fly.io 本番環境の場合:
# BASE_URL=https://your-app.fly.dev

# ── 招待コード ────────────────────────────────
# 知人に共有する招待コード。空欄にするとアクセス制限なし
INVITE_CODE=
